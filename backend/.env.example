# ──────────────────────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/rent_flatmate_finder

# ── Authentication (JWT) ─────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-this-to-a-random-string-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-change-this-too-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── LLM / AI Compatibility Engine ───────────────────────────────────────────
# Provider: "openai" or "claude"
LLM_PROVIDER=openai
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o
# LLM_PROVIDER=claude
# LLM_MODEL=claude-sonnet-4-20250514

# ── Email ────────────────────────────────────────────────────────────────────
# Provider: "resend" or "nodemailer"
EMAIL_PROVIDER=resend
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@rentfinder.com

# For nodemailer (SMTP):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Redis (optional — for Socket.IO adapter in production) ───────────────────
# REDIS_URL=redis://localhost:6379
